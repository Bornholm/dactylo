{
  "manifest_version": 3,
  "name": "Dactylo",
  "version": "0.1.0",
  "description": "Assistant LLM pour la rédaction d'emails dans Thunderbird",
  "browser_specific_settings": {
    "gecko": {
      "id": "dactylo@extension.local",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "compose",
    "storage",
    "messagesRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "compose_action": {
    "default_title": "Dactylo",
    "default_popup": "compose-panel/panel.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_area": "maintoolbar"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png"
  }
}