{
  "name": "dactylo",
  "version": "0.5.0",
  "description": "Extension Thunderbird - Assistant LLM pour la rédaction d'emails",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package": "npm run build && cd dist && zip -r ../dactylo.xpi . && cd ..",
    "clean": "rm -rf dist",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
